# Environment file example for client-management-app
# Copy this to a file named .env and fill in your credentials before starting the server.

# PostgreSQL connection URL format:
# postgresql://<username>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Optional: set server port (defaults to 5000)
#PORT=5000

# Google OAuth placeholders (optional)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_REDIRECT_URI=
# Example .env for local Postgres
# Replace USER, PASSWORD and DBNAME with your values
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# If running locally in development, set:
NODE_ENV=development
# Copy to .env and fill values
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET come from Google Cloud Console -> OAuth 2.0 Client IDs
# Set GOOGLE_REDIRECT_URI to match the OAuth client (example: http://localhost:5000/auth/google/callback)

# WARNING: Do NOT commit a real .env with secrets to version control.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Example redirect (adjust to match your OAuth client or use APP_URL):
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
# Optional: public app URL used to construct callback URL (if different from localhost)
APP_URL=http://localhost:5000

# Server port (default 5000)
PORT=5000

# Copy to .env and fill values
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET come from Google Cloud Console -> OAuth 2.0 Client IDs
# Set GOOGLE_REDIRECT_URI to match the OAuth client (example: http://localhost:5000/auth/google/callback)

# WARNING: Do NOT commit a real .env with secrets to version control.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Example redirect (adjust to match your OAuth client or use APP_URL):
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
# Optional: public app URL used to construct callback URL (if different from localhost)
APP_URL=http://localhost:5000

# Server port (default 5000)
PORT=5000
